{
  "manifest_version": 3,
  "name": "Marks - Bookmarks, AI Reader, Pocket Alt",
  "version": "2.0.0",
  "description": "Save bookmarks to Marks with auto-suggested tags. Sync Kindle highlights.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Marks"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content-twitter.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://getmarks.sh/*",
        "https://marks-drab.vercel.app/*"
      ],
      "js": ["content-marks-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://getmarks.sh/reader/*",
        "https://getmarks.sh/kindle*",
        "https://marks-drab.vercel.app/reader/*",
        "https://marks-drab.vercel.app/kindle*"
      ],
      "js": ["content-marks.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://archive.today/*",
        "https://archive.ph/*",
        "https://archive.is/*",
        "https://archive.li/*",
        "https://archive.vn/*",
        "https://archive.fo/*",
        "https://archive.md/*"
      ],
      "js": ["content-archive.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://read.amazon.com/notebook*"],
      "js": ["content-kindle.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
